# ── PostgreSQL ───────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=postgres
POSTGRES_PORT=5432
LITELLM_DB_NAME=litellm
LANGFUSE_DB_NAME=langfuse
GATEWAY_DB_NAME=gateway

# ── LiteLLM Proxy ───────────────────────────────────
LITELLM_MASTER_KEY=sk-master-changeme
LITELLM_PORT=4000
LITELLM_CLIENT_TIMEOUT=30

# ── LLM Providers (set only the ones you use, others are auto-skipped) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1

# ── Langfuse ────────────────────────────────────────
# Create these in Langfuse UI (http://localhost:3000) after first boot
LANGFUSE_PUBLIC_KEY=pk-lf-changeme
LANGFUSE_SECRET_KEY=sk-lf-changeme
LANGFUSE_NEXTAUTH_SECRET=changeme-nextauth-secret
LANGFUSE_NEXTAUTH_URL=http://localhost:3000
LANGFUSE_SALT=changeme-salt
LANGFUSE_PORT=3000
LANGFUSE_TELEMETRY_ENABLED=false

# ── Gateway API ─────────────────────────────────────
GATEWAY_API_SECRET=changeme-gateway-secret
GATEWAY_API_PORT=8000
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5
AUDIT_HISTORY_DEFAULT_LIMIT=100
PROVIDER_MODELS_PATH=/app/provider_models.yaml
